{
  "name": "brrr",
  "version": "0.2.3",
  "description": "Agent notifications for brrr on macOS",
  "type": "module",
  "bin": {
    "brrr": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "node scripts/generate-version.mjs && tsc -p tsconfig.json && chmod +x dist/src/cli.js",
    "typecheck": "node scripts/generate-version.mjs && tsc -p tsconfig.json --noEmit",
    "test": "node scripts/generate-version.mjs && vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
